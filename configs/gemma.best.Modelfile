# gemma4:e4b - best config (Google Gemma 3n E4B, NO thinking mode)
# Small model (~4B effective). Temp lowered from Gemma's native 1.0 to 0.7 for
# reasoning stability (same lesson as phi4: native high temp = chaos on reasoning).
# top_k 64 / top_p 0.95 are Google's recommended Gemma sampling params.
# ollama create gemma-best -f configs/gemma.best.Modelfile
FROM gemma4:e4b
PARAMETER temperature 0.7
PARAMETER top_k 64
PARAMETER top_p 0.95
PARAMETER num_ctx 8192
