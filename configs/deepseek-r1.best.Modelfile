# deepseek-r1-best - GENERATED from models.json. Do NOT hand-edit; edit models.json + run gen_modelfiles.py.
# CRITICAL: num_ctx MUST be 8192 - the default 131072 = 54 GB = crash on 64 GB. Very slow (~4 tok/s). Dropped from the main fleet (slowest + no winning axis).
# ollama create deepseek-r1-best -f configs/deepseek-r1.best.Modelfile
FROM deepseek-r1:32b
PARAMETER temperature 0.6
PARAMETER num_ctx 8192
PARAMETER num_predict 3000
