# gpt-oss:20b - best config for CODING (thinking HARDCODED - cannot disable, only --think=low for code)
# temp 0.3 (NOT 0 - 100% loops!), num_predict 3000 (thinking does not cut off the response)
# reasoning_effort is NOT a Modelfile PARAMETER - control it via --think=low|medium|high (CLI/API)
# FOR REASONING: use temp 1.0 + --think (default medium), e.g. ollama run gpt-oss-best --think=high
# ollama create gpt-oss-best -f configs/gpt-oss.best.Modelfile
FROM gpt-oss:20b
PARAMETER temperature 0.3
PARAMETER num_predict 3000
PARAMETER num_ctx 8192
