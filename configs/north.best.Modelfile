# north-mini-code-1.0 - best config (Cohere MoE coder, THINKING)
# FOR CODE use: ollama run north-best --think=false "..." (otherwise the code gets lost in the thinking)
# FOR REASONING: leave thinking ON
# ollama create north-best -f configs/north.best.Modelfile
FROM north-mini-code-1.0
PARAMETER temperature 0.7
PARAMETER top_p 0.8
PARAMETER num_ctx 8192
PARAMETER num_predict 3000
