# qwen3.6:35b-a3b - best config (Qwen3.5 35B-A3B ogolny, THINKING) - parametry unsloth
# DO KODU uzywaj: ollama run qwen36-best --think=false "..." (najlepszy koder trudnych zadan!)
# DO REASONINGU: zostaw thinking ON
# Kluczowe vs default: top_p 0.8 (nie 0.95), temp 0.7 (nie 1.0)
# ollama create qwen36-best -f configs/qwen36.best.Modelfile
FROM qwen3.6:35b-a3b
PARAMETER temperature 0.7
PARAMETER top_p 0.8
PARAMETER top_k 20
PARAMETER min_p 0
PARAMETER presence_penalty 1.5
PARAMETER repeat_penalty 1.0
PARAMETER num_ctx 8192
